# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Fast default model for chat and tool use
OPENAI_MODEL=gpt-5-mini

# Embedding model for semantic RAG
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# PostgreSQL for production. If omitted, app falls back to local SQLite.
# Example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bizai
DATABASE_URL=

# App auth secret (change for production)
APP_SECRET_KEY=replace-with-long-random-string

# Public app URL for OAuth callbacks and production links
APP_BASE_URL=https://www.bizaiassistant.com

# Comma-separated frontend origins for browser access in production
ALLOWED_ORIGINS=https://www.bizaiassistant.com

# Optional SMTP (for send_email tool)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://www.bizaiassistant.com/api/auth/google/callback
